{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "txtar",
  "rules": {
    "source_file": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment_section"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "file_entry"
          }
        }
      ]
    },
    "comment_section": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "comment_line"
      }
    },
    "comment_line": {
      "type": "SYMBOL",
      "name": "_content_line"
    },
    "file_entry": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "marker",
          "content": {
            "type": "SYMBOL",
            "name": "file_marker"
          }
        },
        {
          "type": "FIELD",
          "name": "content",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "file_content"
              },
              {
                "type": "BLANK"
              }
            ]
          }
        }
      ]
    },
    "file_content": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "file_content_line"
      }
    },
    "file_content_line": {
      "type": "SYMBOL",
      "name": "_content_line"
    },
    "file_marker": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "marker_start",
          "content": {
            "type": "SYMBOL",
            "name": "marker_start"
          }
        },
        {
          "type": "FIELD",
          "name": "filename",
          "content": {
            "type": "SYMBOL",
            "name": "filename"
          }
        },
        {
          "type": "FIELD",
          "name": "marker_end",
          "content": {
            "type": "SYMBOL",
            "name": "marker_end"
          }
        }
      ]
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "marker_start"
    },
    {
      "type": "SYMBOL",
      "name": "filename"
    },
    {
      "type": "SYMBOL",
      "name": "marker_end"
    },
    {
      "type": "SYMBOL",
      "name": "_content_line"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}