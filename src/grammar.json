{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "txtar",
  "rules": {
    "source_file": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "file_entry"
          }
        }
      ]
    },
    "comment": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "text_line"
      }
    },
    "file_entry": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "marker",
          "content": {
            "type": "SYMBOL",
            "name": "file_marker"
          }
        },
        {
          "type": "FIELD",
          "name": "content",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "file_content"
              },
              {
                "type": "BLANK"
              }
            ]
          }
        }
      ]
    },
    "file_content": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "text_line"
      }
    },
    "file_marker": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "marker_start"
        },
        {
          "type": "FIELD",
          "name": "filename",
          "content": {
            "type": "SYMBOL",
            "name": "filename"
          }
        },
        {
          "type": "SYMBOL",
          "name": "marker_end"
        },
        {
          "type": "PATTERN",
          "value": "\\r?\\n?"
        }
      ]
    },
    "marker_start": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "-- "
          },
          {
            "type": "PATTERN",
            "value": "[ \\t]*"
          }
        ]
      }
    },
    "marker_end": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "PATTERN",
            "value": "[ \\t]*"
          },
          {
            "type": "STRING",
            "value": " --"
          }
        ]
      }
    },
    "filename": {
      "type": "PATTERN",
      "value": "[^\\s-]([^\\n]*[^\\s-])?"
    },
    "text_line": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -1,
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "\\r?\\n"
            },
            {
              "type": "PATTERN",
              "value": "[^-\\n][^\\n]*\\n?"
            },
            {
              "type": "PATTERN",
              "value": "-([^-\\n][^\\n]*)?\\n?"
            },
            {
              "type": "PATTERN",
              "value": "--([^ \\n][^\\n]*)?\\n?"
            }
          ]
        }
      }
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}